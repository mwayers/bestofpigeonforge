{
  "name": "bestofpigeonforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate": "ts-node --project tsconfig.scripts.json scripts/generate.ts",
    "generate:activities": "ts-node --project tsconfig.scripts.json scripts/generate.ts --type activity",
    "generate:itineraries": "ts-node --project tsconfig.scripts.json scripts/generate.ts --type itinerary",
    "generate:comparisons": "ts-node --project tsconfig.scripts.json scripts/generate.ts --type comparison",
    "generate:dry-run": "ts-node --project tsconfig.scripts.json scripts/generate.ts --dry-run --limit 3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.3.1",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
